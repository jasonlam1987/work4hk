{
  "routes": [
    { "src": "/api/ai/(.*)", "dest": "/api/ai/$1" },
    { "src": "/api/wechat/(.*)", "dest": "/api/wechat/$1" },
    { "src": "/api/auth/(check-username|login|check-user-unique|resolve-login-identity|change-password)", "dest": "/api/auth/$1" },
    { "src": "/api/proxy/(.*)", "dest": "/api/proxy/$1" },
    { "src": "/api/(.*)", "dest": "/api/proxy/$1" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
