{
  "name": "work4hk",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:stable": "powershell -ExecutionPolicy Bypass -File scripts/dev-stable.ps1",
    "dev:health": "powershell -ExecutionPolicy Bypass -File scripts/dev-health.ps1",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "check": "tsc -b --noEmit",
    "check:watch": "tsc -b --noEmit --watch --preserveWatchOutput",
    "test:unit": "vitest run --coverage",
    "test:e2e": "playwright test",
    "migrate:storage": "node scripts/migrate-storage-root.mjs",
    "release:est-hk": "node scripts/release-est-hk.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.102.1",
    "axios": "^1.15.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.511.0",
    "openai": "^6.33.0",
    "pinyin-pro": "^3.28.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.3.0",
    "tailwind-merge": "^3.0.2",
    "tencentcloud-sdk-nodejs": "^4.1.209",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@playwright/test": "^1.54.2",
    "@types/node": "^22.15.30",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/coverage-v8": "^2.1.8",
    "autoprefixer": "^10.4.21",
    "babel-plugin-react-dev-locator": "^1.0.0",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^2.1.8"
  }
}
